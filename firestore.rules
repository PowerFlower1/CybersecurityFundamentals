rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isRoomMember(roomId) {
      return exists(/databases/$(database)/documents/rooms/$(roomId)/players/$(request.auth.uid));
    }

    function isValidRoom(data) {
      return data.keys().hasAll(['status', 'hostId', 'hostName', 'createdAt', 'difficulty', 'endTime', 'questionCount', 'timePerQuestion'])
        && data.keys().size() == 8
        && data.status in ['waiting', 'started', 'finished']
        && data.hostId == request.auth.uid
        && data.hostName is string
        && data.createdAt == request.time
        && data.difficulty in ['all', 'easy', 'medium', 'hard']
        && data.endTime is number
        && data.questionCount is number
        && data.timePerQuestion is number;
    }

    function isValidPlayer(data) {
      return data.keys().hasAll(['name', 'score', 'updatedAt'])
        && data.keys().size() == 3
        && data.name is string && data.name.size() > 0 && data.name.size() <= 50
        && data.score == 0
        && data.updatedAt == request.time;
    }

    // NOTE: Instructor access is enforced by the app server's password login,
    // not by Firebase identity, so these rules can only distinguish a room's
    // host (creator) from other users — not "instructors" in general.
    match /rooms/{roomId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();

      allow create: if isSignedIn() && isValidId(roomId) && isValidRoom(incoming());

      allow update: if isSignedIn()
        && existing().hostId == request.auth.uid
        && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'endTime'])
        && incoming().status in ['waiting', 'started', 'finished']
        && incoming().endTime is number
        && incoming().endTime >= 0
        && incoming().endTime <= request.time.toMillis() + 14400000;

      // Instructors get a fresh anonymous UID each browser session, so host-only
      // deletes would strand old rooms. Any signed-in user may delete a room;
      // the dashboard UI only exposes this to instructors.
      allow delete: if isSignedIn();

      match /players/{playerId} {
        allow read: if isSignedIn() && isRoomMember(roomId);

        allow create: if isSignedIn() && isValidId(playerId)
          && playerId == request.auth.uid
          && isValidPlayer(incoming());

        allow update: if isSignedIn()
          && playerId == request.auth.uid
          && incoming().diff(existing()).affectedKeys().hasOnly(['score', 'updatedAt', 'history'])
          && incoming().score is number
          && incoming().score >= existing().score
          && incoming().score - existing().score <= 500
          && incoming().score <= 10000
          && (!incoming().keys().hasAny(['history'])
            || (incoming().history is list && incoming().history.size() <= 50))
          && incoming().updatedAt == request.time;
      }
    }

    match /{path=**}/players/{playerId} {
       allow read: if isSignedIn();
    }

    match /questions/{questionId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
